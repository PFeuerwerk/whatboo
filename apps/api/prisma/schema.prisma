datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// MODELOS DEL ECOSISTEMA MULTI-TENANT WHATBOO
// ==========================================

enum RestaurantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  OWNER
  MANAGER
  MAITRE
  STAFF
}

enum ShiftType {
  LUNCH
  DINNER
  FULL_TIME
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ReservationSource {
  WHATSAPP
  DASHBOARD
}

model Restaurant {
  id                         String           @id @default(uuid())
  slug                       String           @unique
  name                       String
  phone                      String
  status                     RestaurantStatus @default(ACTIVE)
  createdAt                  DateTime         @default(now())
  deletedAt                  DateTime?
  
  // Parámetros comerciales dinámicos y personalizables
  slotIntervalMinutes        Int              @default(30)
  bufferTimeMinutes          Int              @default(15)
  defaultReservationDuration Int              @default(90)
  autoConfirm                Boolean          @default(true)
  allowWaitlist              Boolean          @default(true)
  closingHourLimit           String           @default("03:00")

  // Credenciales Meta Cloud API encriptadas
  phoneNumberId              String?
  businessAccountId          String?
  accessToken                String?
  appSecret                  String?

  users                      User[]
  zones                      RestaurantZone[]
  tables                     RestaurantTable[]
  reservations               Reservation[]
  customers                  Customer[]

  @@map("restaurants")
}

model User {
  id                  String      @id @default(uuid())
  email               String      @unique
  firstName           String
  lastName            String
  passwordHash        String
  role                UserRole    @default(STAFF)
  shift               ShiftType   @default(FULL_TIME)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  
  // SANEADO: Columnas de control de login exigidas por tu AuthService nativo
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  restaurantId        String
  restaurant          Restaurant  @relation(fields: [restaurantId], references: [id])

  @@map("users")
}

model RestaurantZone {
  id           String            @id @default(uuid())
  name         String
  priority     Int               @default(1)
  active       Boolean           @default(true)

  restaurantId String
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id])
  tables       RestaurantTable[]

  @@map("restaurant_zones")
}

model RestaurantTable {
  id           String            @id @default(uuid())
  name         String
  capacity     Int
  active       Boolean           @default(true)

  restaurantId String
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id])
  zoneId       String
  zone         RestaurantZone    @relation(fields: [zoneId], references: [id])
  reservations ReservationTable[]

  @@map("restaurant_tables")
}

model Customer {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  phone        String
  email        String?
  allergies    String[]
  notes        String?

  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  reservations Reservation[]

  @@map("customers")
}

model Reservation {
  id               String            @id @default(uuid())
  reservationDate  DateTime
  reservationStart DateTime
  reservationEnd   DateTime
  guestCount       Int
  status           ReservationStatus @default(PENDING)
  source           ReservationSource @default(WHATSAPP)
  notes            String?
  confirmationCode String?           @unique
  
  pax              Int               @default(2)
  timeSlot         String            @default("13:00")

  restaurantId     String
  restaurant       Restaurant        @relation(fields: [restaurantId], references: [id])
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id])
  tables           ReservationTable[]

  @@map("reservations")
}

model ReservationTable {
  reservationId String
  tableId       String
  assignedAt    DateTime    @default(now())
  autoAssigned  Boolean     @default(true)

  reservation   Reservation @relation(fields: [reservationId], references: [id])
  table         RestaurantTable @relation(fields: [tableId], references: [id])

  @@id([reservationId, tableId])
  @@map("reservation_tables")
}

model WhatsappInboundLog {
  id             String   @id @default(uuid())
  rawPhoneNumber String
  isValid        Boolean  @default(false)
  reason         String
  errorMessage   String
  createdAt      DateTime @default(now())

  @@map("whatsapp_inbound_logs")
}
