{
  "name": "api",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "start:watch": "ts-node --watch src/main.ts",
    "test:e2e": "NODE_ENV=test prisma migrate deploy && NODE_ENV=test node --test --test-force-exit -r ts-node/register/transpile-only test/dashboard-api.e2e-spec.ts",
    "openapi:validate": "node scripts/validate-openapi.mjs",
    "smoke": "node scripts/smoke-api.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "start:debug": "ts-node-dev --respawn --transpile-only --inspect src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.26",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/cookie": "^1.0.0",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.0.0",
    "form-data": "^4.0.6",
    "handlebars": "^4.7.9",
    "ioredis": "^5.11.1",
    "joi": "^18.2.1",
    "libphonenumber-js": "^1.13.6",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.4",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.16",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "type": "commonjs",
  "license": "ISC"
}
